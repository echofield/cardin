# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx

# Optional wallet provider templates
APPLE_WALLET_PASS_URL_TEMPLATE=https://wallet.yourdomain.com/apple/{cardId}
GOOGLE_WALLET_PASS_URL_TEMPLATE=https://wallet.yourdomain.com/google/{cardId}

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email / SMTP
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@getcardin.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=contact@getcardin.com
CONTACT_TO_EMAIL=contact@getcardin.com

# Site URL
CARDIN_SITE_URL=https://getcardin.com